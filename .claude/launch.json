{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Backend (Express + WebSocket)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--watch", "server.js"],
      "port": 3001,
      "cwd": "backend"
    },
    {
      "name": "Frontend (Vite)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vite"],
      "port": 3000,
      "cwd": "frontend"
    }
  ]
}

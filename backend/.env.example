# ═══════════════════════════════════════════════════════════════
# RomainGE — Variables de entorno
# ═══════════════════════════════════════════════════════════════

# ─── Anthropic (Claude API) ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxx
CLAUDE_MODEL=claude-sonnet-4-20250514

# ─── Twilio ──────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=xxxxx
TWILIO_PHONE_NUMBER=+34900000000
# Para número español 900 (gratuito), contratar vía Twilio España
# Alternativa más barata: número local +34 91X o +34 93X

# ─── Servidor ────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
BASE_URL=https://romainge.com
API_SECRET=your-random-secret-key-here-min-32-chars

# ─── JWT Authentication ──────────────────────────────────────
# Secret for signing JWT tokens (defaults to API_SECRET if not set)
JWT_SECRET=your-jwt-secret-64-chars-recommended
JWT_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=24h
SESSION_INACTIVITY_MINUTES=30

# ─── Sesiones ────────────────────────────────────────────────
SESSION_TTL_HOURS=24
SESSION_ENCRYPTION_KEY=another-random-key-32-chars-min

# ─── PostgreSQL (Prisma — primary database) ──────────────────
# Set DATABASE_URL to use PostgreSQL for sessions, messages, call history, etc.
# DATABASE_URL=postgresql://user:password@localhost:5432/romainge
# DATABASE_URL=postgresql://user:password@host.railway.internal:5432/railway

# ─── Redis (cache & fallback sessions) ───────────────────────
# If no DATABASE_URL: Redis is used for sessions.
# If DATABASE_URL is set: Redis is used only for response cache.
# REDIS_URL=redis://default:xxxxx@host:6379
# REDIS_URL=rediss://default:xxxxx@eu1-xxxxx.upstash.io:6379

# ─── Soft-delete retention ───────────────────────────────────
SESSION_RETENTION_DAYS=90

# ─── Response cache ──────────────────────────────────────────
RESPONSE_CACHE_TTL=3600
RESPONSE_CACHE_MAX_SIZE=500

# ─── File uploads ────────────────────────────────────────────
# UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
# S3_BUCKET=romainge-docs
# AWS_REGION=eu-west-1

# ─── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Twilio Voice Config ────────────────────────────────────
# Idioma para Speech-to-Text
STT_LANGUAGE=es-ES
# Voz para Text-to-Speech (Neural española)
TTS_VOICE=Polly.Lucia-Neural
# Tiempo máximo de espera para entrada de voz (segundos)
SPEECH_TIMEOUT=3

# ─── Twilio Voice Advanced ─────────────────────────────────
# Modelo rápido para clasificación y respuestas de voz (reduce latencia)
CLAUDE_FAST_MODEL=claude-haiku-4-5-20251001
# Máximo de llamadas simultáneas (ConversationRelay)
MAX_CONCURRENT_CALLS=10
# Número de agente humano para transferencias
# HUMAN_AGENT_PHONE=+34600000000
# Habilitar grabación de llamadas (requiere consentimiento del llamante)
ENABLE_RECORDING=false
# Habilitar supervisor de calidad en respuestas
ENABLE_SUPERVISOR=false

# ─── Twilio Verify (SMS phone verification) ──────────────────
# TWILIO_VERIFY_SID=VAxxxxx

# ─── Admin Dashboard ──────────────────────────────────────────
ADMIN_EMAIL=admin@romainge.com
ADMIN_NAME=Admin
# Generate with: node -e "const c=require('crypto');console.log(c.createHash('sha256').update('yourpassword'+process.env.API_SECRET).digest('hex'))"
# ADMIN_PASSWORD_HASH=
# ADMIN_JWT_SECRET=your-admin-jwt-secret
FRONTEND_URL=https://romainge.com

# ─── Email Alerts (SMTP) ─────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=alerts@romainge.com
# SMTP_PASS=xxxx
# SMTP_FROM=alertas@romainge.com
ALERT_EMAILS=admin@romainge.com
QUEUE_ALERT_THRESHOLD=50

# ─── Cost Monitoring ─────────────────────────────────────────
TWILIO_RATE_PER_MIN=0.015

# ─── Sentry Error Tracking ──────────────────────────────────
# SENTRY_DSN_BACKEND=https://xxxxx@o123456.ingest.sentry.io/654321
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ─── Feature Flags ──────────────────────────────────────────
# Override any flag with FF_ prefix: FF_VOICE_RELAY_ENABLED=false
# FF_SENTRY_ENABLED=true
# FF_MULTI_TENANT=true

# ─── WhatsApp (Twilio WhatsApp API) ────────────────────────
# TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
# WHATSAPP_RATE_LIMIT=20

# ─── Google Calendar Integration ───────────────────────────
# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx
# GOOGLE_REDIRECT_URI=https://api.romainge.com/api/calendar/oauth/callback

# ─── Public API ─────────────────────────────────────────────
# PUBLIC_API_ENABLED=true

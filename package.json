{
  "name": "romainge",
  "version": "1.0.0",
  "private": true,
  "description": "RomainGE — Plataforma de Gestión Fiscal con IA",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "install:all": "cd backend && npm install && cd ../frontend && npm install",
    "build:frontend": "cd frontend && npm run build",
    "deploy:backend": "cd backend && vercel --prod",
    "deploy:frontend": "cd frontend && vercel --prod",
    "deploy:all": "npm run deploy:backend && npm run deploy:frontend",
    "setup:twilio": "cd backend && npm run setup:twilio"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
